{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "clash-mg 主窗口、连接子窗口与连接详情子窗口权限",
  "windows": ["main", "connections-window", "connection-detail-*"],
  "permissions": [
    "core:default",
    "allow-open-connections-window",
    "allow-open-connection-detail-window",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-set-focus"
  ]
}
