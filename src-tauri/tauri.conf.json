{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clash-mg",
  "version": "0.0.4",
  "identifier": "com.clashmg.desktop",
  "build": {
    "beforeDevCommand": "npm run prepare:mihomo && npm run dev",
    "devUrl": "http://localhost:8220",
    "beforeBuildCommand": "npm run prepare:mihomo && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/mihomo"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
