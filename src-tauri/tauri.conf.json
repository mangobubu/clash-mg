{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clash-mg",
  "version": "0.1.0",
  "identifier": "com.clashmg.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8220",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
